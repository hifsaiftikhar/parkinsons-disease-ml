    {
      "cell_type": "code",
      "source": [
        "## STEP 7: Train and Evaluate All Models\n",
        "print('='*80)\n",
        "print('TRAINING AND EVALUATING ALL MODELS')\n",
        "print('Training on: D1 Train | Validating on: D1 Test | Final Test on: D3 Test')\n",
        "print('='*80)\n",
        "\n",
        "all_results   = []   # stores metrics for comparison table\n",
        "trained_models = {}  # stores trained model objects for later use\n",
        "\n",
        "for model_name, model in models.items():\n",
        "    print(f'\\n{\"-\"*60}')\n",
        "    print(f'MODEL: {model_name}')\n",
        "    print(f'{\"-\"*60}')\n",
        "\n",
        "    # Train on D1 training set\n",
        "    model.fit(X_train, y_train)\n",
        "    trained_models[model_name] = model\n",
        "    print(f'  Trained on D1 train set ({X_train.shape[0]} samples)')\n",
        "\n",
        "    # Cross-validation on training data (5-fold)\n",
        "    cv_scores = cross_val_score(model, X_train, y_train, cv=5, scoring='f1')\n",
        "    print(f'  Cross-validation F1 (5-fold): {cv_scores.mean():.4f} +/- {cv_scores.std():.4f}')\n",
        "\n",
        "    # Evaluate on D1 validation set\n",
        "    val_metrics, _, _ = evaluate_model(model, X_val, y_val, 'D1 Test')\n",
        "    print(f'  D1 Test  -> Acc: {val_metrics[\"Accuracy\"]:.4f} | F1: {val_metrics[\"F1\"]:.4f} | AUC: {val_metrics[\"AUC-ROC\"]:.4f}')\n",
        "\n",
        "    # Evaluate on D3 test set (cross-dataset generalization)\n",
        "    d3_metrics, _, _ = evaluate_model(model, X_d3_test, y_d3_test, 'D3 Test')\n",
        "    print(f'  D3 Test  -> Acc: {d3_metrics[\"Accuracy\"]:.4f} | F1: {d3_metrics[\"F1\"]:.4f} | AUC: {d3_metrics[\"AUC-ROC\"]:.4f}')\n",
        "\n",
        "    # Overfitting check\n",
        "    train_metrics, _, _ = evaluate_model(model, X_train, y_train, 'D1 Train')\n",
        "    gap = train_metrics['F1'] - d3_metrics['F1']\n",
        "    if gap > 0.15:\n",
        "        print(f'  WARNING: Possible overfitting. Train F1={train_metrics[\"F1\"]:.4f}, D3 F1={d3_metrics[\"F1\"]:.4f} (gap={gap:.4f})')\n",
        "    else:\n",
        "        print(f'  No significant overfitting detected (gap={gap:.4f})')\n",
        "\n",
        "    # Store results\n",
