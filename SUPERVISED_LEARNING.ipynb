        "\n",
        "print('Dataset 1 train shape:', d1_train.shape)\n",
        "print('Dataset 1 test shape: ', d1_test.shape)\n",
        "print('Dataset 3 train shape:', d3_train.shape)\n",
        "print('Dataset 3 test shape: ', d3_test.shape)\n",
        "\n",
        "print('\\nDataset 1 columns:', d1_train.columns.tolist())\n",
        "print('Dataset 3 columns:', d3_train.columns.tolist())"
      ],
