    {
      "cell_type": "code",
      "source": [
        "## STEP 6: Define All Models\n",
        "# All models with class_weight='balanced' where supported\n",
        "# class_weight='balanced' compensates for class imbalance automatically\n",
        "\n",
        "models = {\n",
        "    'Logistic Regression': LogisticRegression(\n",
        "        max_iter=1000,\n",
        "        class_weight='balanced',\n",
        "        random_state=42\n",
        "    ),\n",
        "    'KNN': KNeighborsClassifier(\n",
        "        n_neighbors=5\n",
        "        # KNN does not support class_weight\n",
        "    ),\n",
        "    'Naive Bayes': GaussianNB(\n",
        "        # Naive Bayes does not support class_weight\n",
        "    ),\n",
        "    'Decision Tree': DecisionTreeClassifier(\n",
        "        max_depth=5,\n",
        "        class_weight='balanced',\n",
        "        random_state=42\n",
        "    ),\n",
        "    'Random Forest': RandomForestClassifier(\n",
        "        n_estimators=100,\n",
        "        class_weight='balanced',\n",
        "        random_state=42\n",
        "    ),\n",
        "    'SVM': SVC(\n",
        "        kernel='rbf',\n",
        "        class_weight='balanced',\n",
        "        probability=True,\n",
        "        random_state=42\n",
        "    ),\n",
        "    'Gradient Boosting': GradientBoostingClassifier(\n",
        "        n_estimators=100,\n",
        "        random_state=42\n",
        "        # Gradient Boosting does not support class_weight\n",
        "        # It handles imbalance through boosting naturally\n",
        "    )\n",
        "}\n",
        "\n",
        "print(f'{len(models)} models defined:')\n",
        "for name in models:\n",
        "    print(f'  - {name}')"
      ],
