    },
    {
      "cell_type": "code",
      "source": [
        "## STEP 3: Prepare Features and Targets\n",
        "# Separate features and target for D1\n",
        "X_train = d1_train.drop('status', axis=1)\n",
        "y_train = d1_train['status']\n",
        "\n",
        "X_val   = d1_test.drop('status', axis=1)\n",
        "y_val   = d1_test['status']\n",
        "\n",
        "# For D3 — use only common features that exist in both datasets\n",
        "common_features = [col for col in X_train.columns if col in d3_test.columns]\n",
        "print(f'Common features between D1 and D3: {len(common_features)}')\n",
        "print(f'Features in D1 only: {[c for c in X_train.columns if c not in d3_test.columns]}')\n",
        "print(f'Features in D3 only: {[c for c in d3_test.columns if c not in X_train.columns and c != \"status\"]}')\n",
        "\n",
        "# Align all sets to common features\n",
        "X_train = X_train[common_features]\n",
        "X_val   = X_val[common_features]\n",
        "\n",
        "X_d3_test = d3_test.drop('status', axis=1)[common_features]\n",
        "y_d3_test = d3_test['status']\n",
        "\n",
        "print(f'\\nFinal shapes:')\n",
        "print(f'  X_train (D1 train):  {X_train.shape}')\n",
        "print(f'  X_val   (D1 test):   {X_val.shape}')\n",
        "print(f'  X_d3_test (D3 test): {X_d3_test.shape}')"
      ],
